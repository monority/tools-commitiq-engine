{
  "name": "commitiq-engine",
  "version": "3.0.2",
  "description": "CommitIQ Engine: diff-aware commit quality intelligence for staged changes and release-safe Git workflows.",
  "type": "module",
  "main": "scripts/cli.js",
  "bin": {
    "commitiq-engine": "scripts/cli.js",
    "cq": "scripts/cli.js",
    "cqc": "scripts/cli.js"
  },
  "exports": {
    ".": "./scripts/cli.js"
  },
  "files": [
    "scripts",
    "src",
    "cq",
    "cqc"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "node --test ./test/*.test.js",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "git",
    "pre-commit",
    "husky",
    "eslint",
    "prettier",
    "quality",
    "commit",
    "diff-aware",
    "release",
    "guard"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monority/tools-commitiq-engine.git"
  },
  "homepage": "https://github.com/monority/tools-commitiq-engine#readme",
  "bugs": {
    "url": "https://github.com/monority/tools-commitiq-engine/issues"
  },
  "author": "Ronan Chenu <ronan.chenu@example.com>",
  "license": "MIT",
  "dependencies": {
    "execa": "^9.5.2",
    "husky": "^9.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "gitQuality": {
    "skip": [
      "Debug Artifacts",
      "Playwright Tests"
    ],
    "autoPush": false
  }
}
