{
  "name": "commit-quality-check",
  "version": "1.0.21",
  "description": "Pre-commit quality checks for staged files and project scripts.",
  "type": "module",
  "main": "scripts/cli.js",
  "bin": {
    "commit-quality-check": "scripts/cli.js",
    "cqc": "scripts/cli.js"
  },
  "exports": {
    ".": "./scripts/cli.js"
  },
  "files": [
    "scripts",
    "src",
    "cqc"
  ],
  "scripts": {
    "test": "node --test ./test/*.test.js",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "git",
    "pre-commit",
    "husky",
    "eslint",
    "prettier",
    "quality"
  ],
  "author": "Ronan Chenu <ronan.chenu@example.com>",
  "license": "MIT",
  "dependencies": {
    "commit-quality-check": "^1.0.7",
    "execa": "^9.5.2",
    "husky": "^9.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "gitQuality": {
    "skip": [
      "Debug Artifacts",
      "Playwright Tests"
    ],
    "autoPush": false
  }
}
